# Rahatio Production Env
APP_ENV=production
APP_DEBUG=false
APP_KEY=

NGINX_PORT=3680

# Production DB parolalari -> Portainer env'den set edilir (burada placeholder)
MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_DATABASE=rahatio
MYSQL_USER=rahatio
MYSQL_PASSWORD=change-me-db
MYSQL_ROOT_PASSWORD_FILE=
MYSQL_PASSWORD_FILE=

