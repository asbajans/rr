REDIS_PORT=6379

INTEGRATION_SERVICE_URL=http://rahatio-integration:3001

# Trendyol
TRENDYOL_API_KEY=
TRENDYOL_API_SECRET=
TRENDYOL_SUPPLIER_ID=

# Hepsiburada
HB_USERNAME=
HB_PASSWORD=

# Core API (integration -> core-engine auth)
