APP_ENV=production
APP_DEBUG=false

# Core (laravel-app) host port — nginx internal 80
NGINX_PORT=3680

# Frontend (Next.js) host port
FRONTEND_PORT=3690

# MySQL
MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_DATABASE=rahatio
MYSQL_USER=rahatio
MYSQL_PASSWORD=change-me-db

# Redis (no password by default)
REDIS_HOST=redis
REDIS_PASSWORD=
REDIS_PORT=6379

# MinIO (S3-compatible storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=rahatio

# AI service
AI_SERVICE_URL=http://rahatio-ai:3000

# Integration service
INTEGRATION_SERVICE_URL=http://rahatio-integration:3001

# Internal API key (core <-> services)
CORE_API_KEY=
RAHAT_INTERNAL_KEY=change-me-internal-key

# Trendyol integration
TRENDYOL_API_KEY=
TRENDYOL_API_SECRET=
TRENDYOL_SUPPLIER_ID=

# Hepsiburada integration
HB_USERNAME=
HB_PASSWORD=
HB_MERCHANT_ID=

# Pazarama integration
PAZARAMA_CLIENT_ID=
PAZARAMA_CLIENT_SECRET=
PAZARAMA_API_KEY=

# N11 integration
N11_USERNAME=
N11_PASSWORD=

# Amazon TR (SP-API) - mağaza bazlı panelden de girilebilir
AMAZON_REFRESH_TOKEN=
AMAZON_LWA_CLIENT_ID=
AMAZON_LWA_CLIENT_SECRET=
AMAZON_AWS_ACCESS_KEY=
AMAZON_AWS_SECRET_KEY=
AMAZON_SELLER_ID=
AMAZON_MARKETPLACE_ID=A1O49J7X5Y7RJA

# ComfyUI / Ollama (used by ai-service, host.docker.internal)
COMFY_URL=http://host.docker.internal:8188
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_LLM_MODEL=llama3
LLM_MODEL=llama3
VISION_MODEL=llama3.2-vision
FCM_SERVER_KEY=

# Stripe (subscriptions + credit purchases)
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
