APP_ENV=production
APP_DEBUG=false

# Core (laravel-app) host port — nginx internal 80
NGINX_PORT=3680

# Frontend (Next.js) host port
FRONTEND_PORT=3690

# MySQL
MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_DATABASE=rahatio
MYSQL_USER=rahatio
MYSQL_PASSWORD=change-me-db

# Redis (no password by default)
REDIS_HOST=redis
REDIS_PASSWORD=
REDIS_PORT=6379

# MinIO (S3-compatible storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=rahatio

# AI service
AI_SERVICE_URL=http://rahatio-ai:3000

# Integration service
INTEGRATION_SERVICE_URL=http://rahatio-integration:3001

# Internal API key (core <-> services)
CORE_API_KEY=
RAHAT_INTERNAL_KEY=change-me-internal-key

# Trendyol integration
TRENDYOL_API_KEY=
TRENDYOL_API_SECRET=
TRENDYOL_SUPPLIER_ID=

# Hepsiburada integration
HB_USERNAME=
HB_PASSWORD=

# ComfyUI / Ollama (used by ai-service, host.docker.internal)
COMFY_URL=http://host.docker.internal:8188
OLLAMA_URL=http://host.docker.internal:11434
FCM_SERVER_KEY=
