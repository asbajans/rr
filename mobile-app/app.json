{
  "expo": {
    "name": "Rahatio",
    "slug": "rahatio",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "rahatio",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rahatio.mobile"
    },
    "android": {
      "package": "com.rahatio.mobile",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Rahatio needs access to your photos to process images with AI."
        }
      ],
      "expo-asset"
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "6bb13aed-b1f2-482f-9327-86b5eb6c6315"
      }
    },
    "owner": "ahmedsaidbuluts-team",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/6bb13aed-b1f2-482f-9327-86b5eb6c6315"
    }
  }
}
