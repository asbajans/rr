{
  "expo": {
    "name": "Rahatio",
    "slug": "rahatio-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "rahatio",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rahatio.mobile"
    },
    "android": {
      "package": "com.rahatio.mobile"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Rahatio needs access to your photos to process images with AI."
        }
      ],
      "expo-asset"
    ]
  }
}
