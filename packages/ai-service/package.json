    "form-data": "^4.0.0",
    "multer": "^1.4.5-lts.1",
    "ollama": "^0.5.0",
    "sharp": "^0.33.0",
    "uuid": "^9.0.0",
    "socket.io": "^4.7.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/multer": "^1.4.11",
    "@types/uuid": "^9.0.8",
    "@types/socket.io": "^3.0.0",
    "typescript": "^5.4.0",
    "tsx": "^4.7.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "vitest": "^1.4.0"
