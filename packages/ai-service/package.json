{
  "name": "@rahatio/ai-service",
  "version": "2.0.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && tsc -p tsconfig.build.json",
