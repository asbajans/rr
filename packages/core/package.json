{
  "name": "@rahatio/core",
  "version": "2.0.0",
  "private": true,
  "main": "dist/server.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc && tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:migrate": "sequelize-cli db:migrate",
    "db:seed": "tsx src/scripts/seed.ts",
    "db:seed:cli": "sequelize-cli db:seed:all",
    "db:create": "sequelize-cli db:create",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "aws-sdk": "^2.1600.0",
    "axios": "^1.7.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.8.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "dotenv": "^16.4.0",
    "express": "^4.19.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.0",
    "joi": "^17.13.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "pg": "^8.11.0",
    "pg-hstore": "^2.3.4",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "redis": "^4.6.0",
    "sequelize": "^6.37.0",
    "sequelize-typescript": "^2.1.6",
    "sharp": "^0.33.0",
    "stripe": "^15.0.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.12.0",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^1.4.0",
    "eslint": "^8.57.0",
    "sequelize-cli": "^6.6.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  }
}